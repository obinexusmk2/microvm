{
  "schemaVersion": "0.1",
  "name": "mixed-demo",
  "version": "0.1.0",
  "allowedRuntimes": ["python", "node"],
  "permissions": {
    "network": {
      "outbound": false,
      "ports": [8766]
    },
    "filesystem": []
  },
  "components": [
    {
      "name": "api",
      "runtime": "python",
      "workingDirectory": "./components/api",
      "command": ["python", "server.py"],
      "ports": [8766],
      "healthCheck": {
        "type": "http",
        "url": "http://127.0.0.1:8766/health",
        "intervalSeconds": 1,
        "timeoutSeconds": 2
      },
      "environment": {
        "PYTHONUNBUFFERED": "1",
        "MICROVM_DEMO_PORT": "8766"
      }
    },
    {
      "name": "worker",
      "runtime": "node",
      "workingDirectory": "./components/worker",
      "command": ["node", "index.js"],
      "stdio": true,
      "dependsOn": ["api"],
      "environment": {
        "NODE_ENV": "production"
      }
    }
  ]
}
